{
  "name": "lumen-bloom",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "現在地の太陽位置と天気をリアルタイムに映す、プロシージャル花瓶の3Dウォールペーパー",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "three": "0.185.1"
  },
  "devDependencies": {
    "@types/three": "^0.185.0",
    "@vitest/coverage-v8": "^4.1.6",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "^4.1.6"
  }
}
